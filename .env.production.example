# Production Environment Variables Template
# Copy this file to .env and fill in your production values
# IMPORTANT: Never commit .env to version control!

# ============================================
# Database Configuration
# ============================================
POSTGRES_DB=easypost
POSTGRES_USER=easypost_admin
POSTGRES_PASSWORD=your-secure-password-here
POSTGRES_INITDB_ARGS="--encoding=UTF8 --lc-collate=C --lc-ctype=C"

# ============================================
# Redis Configuration
# ============================================
REDIS_PASSWORD=your-redis-password-here

# ============================================
# WAHA (WhatsApp) Configuration
# ============================================
WAHA_API_KEY=your-waha-api-key-here
WAHA_SESSION=easypost_session
WAHA_ENGINE=WEBJS
WAHA_START_SESSION=true
WAHA_RESTART_SESSION_ON_TEARDOWN=true
WAHA_DEBUG=false
WAHA_HOST=0.0.0.0
WAHA_PORT=8080

# ============================================
# OpenAI Configuration
# ============================================
# Get your API key from: https://platform.openai.com/api-keys
OPENAI_API_KEY=sk-your-actual-key-here
OPENAI_MODEL=gpt-4o
OPENAI_TEMPERATURE=0.7

# ============================================
# AWS Configuration
# ============================================
# Create IAM user at: https://console.aws.amazon.com/iam/
# Required permissions: S3, EC2, CloudWatch
AWS_ACCESS_KEY_ID=your-aws-access-key-id
AWS_SECRET_ACCESS_KEY=your-aws-secret-access-key
AWS_REGION=us-east-1
AWS_S3_BUCKET_NAME=easypost-production-bucket

# ============================================
# Clerk Authentication
# ============================================
# Get keys from: https://dashboard.clerk.com/
CLERK_SECRET_KEY=sk_live_your-clerk-secret-key
CLERK_PUBLISHABLE_KEY=pk_live_your-clerk-publishable-key

# ============================================
# Security Keys (Generate new values for production!)
# ============================================
# Generate these with: openssl rand -base64 32
JWT_SECRET=your-jwt-secret-key-generated-here
ENCRYPTION_KEY=your-encryption-key-generated-here
API_KEY=your-api-key-generated-here

# ============================================
# Application Configuration
# ============================================
ENVIRONMENT=production
DEBUG=false
LOG_LEVEL=INFO
# Comma-separated list of allowed origins
CORS_ORIGINS=https://yourdomain.com,https://www.yourdomain.com,https://api.yourdomain.com

# ============================================
# Frontend Configuration
# ============================================
VITE_API_URL=https://api.yourdomain.com
VITE_WS_URL=wss://api.yourdomain.com/ws
VITE_CLERK_PUBLISHABLE_KEY=pk_live_your-clerk-publishable-key
VITE_CLOUDINARY_CLOUD_NAME=your-cloudinary-cloud-name
VITE_ENVIRONMENT=production
VITE_APP_NAME=EasyPost AI
VITE_DEBUG=false

# ============================================
# Monitoring & Observability
# ============================================
# Sentry error tracking: https://sentry.io/
SENTRY_DSN=https://your-sentry-dsn-here@sentry.io/your-project-id

# New Relic APM: https://newrelic.com/
NEW_RELIC_KEY=your-new-relic-license-key

# ============================================
# Email Configuration (Optional)
# ============================================
# For transactional emails
SMTP_SERVER=smtp.gmail.com
SMTP_PORT=587
SMTP_USERNAME=your-email@gmail.com
SMTP_PASSWORD=your-app-specific-password
SENDER_EMAIL=noreply@yourdomain.com

# ============================================
# MCP Server Configuration
# ============================================
MCP_SERVER_URL=http://mcp-server:9000
MCP_PORT=9000

# ============================================
# Build Configuration
# ============================================
BUILD_TARGET=production

# ============================================
# SSL/TLS Configuration
# ============================================
# These are typically managed by Certbot/Let's Encrypt
SSL_CERT_PATH=/etc/letsencrypt/live/yourdomain.com/fullchain.pem
SSL_KEY_PATH=/etc/letsencrypt/live/yourdomain.com/privkey.pem

# ============================================
# Backup Configuration
# ============================================
BACKUP_S3_BUCKET=easypost-backups
BACKUP_RETENTION_DAYS=30

# ============================================
# Additional Configuration
# ============================================
# Meta (Facebook/Instagram) API tokens
META_ACCESS_TOKEN=your-meta-access-token
META_BUSINESS_ACCOUNT_ID=your-meta-business-account-id

# Database backup destination
DB_BACKUP_LOCATION=/data/backups

# Max upload size in MB
MAX_UPLOAD_SIZE_MB=100

# API rate limiting
API_RATE_LIMIT=100  # requests per minute
AUTH_RATE_LIMIT=5   # login attempts per minute

# Session configuration
SESSION_TIMEOUT_MINUTES=1440  # 24 hours
TOKEN_EXPIRY_HOURS=24

# Enable/disable features
ENABLE_USER_REGISTRATION=true
ENABLE_SOCIAL_LOGIN=true
ENABLE_TWO_FACTOR_AUTH=true

# Notification settings
SEND_EMAIL_NOTIFICATIONS=true
SEND_SMS_NOTIFICATIONS=false
