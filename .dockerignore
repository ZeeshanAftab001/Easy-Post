# .dockerignore

# Git
.git
.gitignore

# Node
node_modules
npm-debug.log
dist

# Python
__pycache__
*.pyc
*.pyo
*.pyd
.venv
venv
env
.env
.env.*

# IDE
.vscode
.idea
.DS_Store

# Temporary
tmp
temp
*.log

# Build artifacts
*.egg-info
.tox
.coverage
.cache
.pytest_cache

# Media/Uploads (these should be mounted at runtime)
media/
uploads/
static/

# Docker related (keep Dockerfiles but ignore logs/configs if not needed context)
*.log
docker-compose*.yml
.dockerignore
